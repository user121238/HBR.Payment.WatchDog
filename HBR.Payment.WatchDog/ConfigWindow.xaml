<Window x:Class="HBR.Payment.WatchDog.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HBR.Payment.WatchDog"
        Title="HBR 支付看门狗"
        Width="1260"
        Height="640"
        MinWidth="1080"
        MinHeight="520"
        Background="#FFF5F5F5"
        Icon="z3du2-0fupz-001.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:StatusBrushConverter x:Key="StatusBrushConverter" />
        <!--  Icon="pack://application:,,,/HBR.Payment.WatchDog;component/z3du2-0fupz-001.ico"  -->
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE7E7E7" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF181818" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF6F6F6F" />
        <SolidColorBrush x:Key="ButtonFillBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FFDADADA" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FFF3F3F3" />
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FFECECEC" />
        <SolidColorBrush x:Key="DangerButtonFillBrush" Color="#FFFCEEEE" />
        <SolidColorBrush x:Key="DangerButtonBorderBrush" Color="#FFE3B7B7" />
        <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="#FFF9E2E2" />
        <SolidColorBrush x:Key="DangerButtonPressedBrush" Color="#FFF5D7D7" />
        <SolidColorBrush x:Key="DangerButtonTextBrush" Color="#FFA63E3E" />
        <SolidColorBrush x:Key="HeaderFillBrush" Color="#FFFAFAFA" />
        <SolidColorBrush x:Key="GridLineBrush" Color="#FFF0F0F0" />
        <SolidColorBrush x:Key="RowHoverBrush" Color="#FFF8F8F8" />
        <SolidColorBrush x:Key="RowSelectedBrush" Color="#FFECECEC" />
        <SolidColorBrush x:Key="RowSelectedTextBrush" Color="#FF111111" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ButtonFillBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ButtonFillBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" BasedOn="{StaticResource ToolButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="#FF121212" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF121212" />
        </Style>

        <Style x:Key="DangerButtonStyle" BasedOn="{StaticResource ToolButtonStyle}" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource DangerButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerButtonBorderBrush}" />
            <Setter Property="Background" Value="{StaticResource DangerButtonFillBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource DangerButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource DangerButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="GridEditingTextBoxStyle" BasedOn="{StaticResource InputTextBoxStyle}" TargetType="TextBox">
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLineBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="RowHeight" Value="46" />
            <Setter Property="ColumnHeaderHeight" Value="46" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderFillBrush}" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowSelectedBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource RowSelectedTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="进程守护管理" />
            <TextBlock Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="以简洁方式维护受管进程、启动顺序与运行状态。" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,18"
                Padding="16"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <DockPanel LastChildFill="False">
                <StackPanel VerticalAlignment="Center" DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="检查间隔（秒）" />
                    <TextBox x:Name="CheckIntervalTextBox"
                             Width="90"
                             Margin="12,0,0,0"
                             Style="{StaticResource InputTextBoxStyle}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Click="RefreshButton_OnClick" Content="刷新状态" Style="{StaticResource ToolButtonStyle}" />
                    <Button Margin="0"
                            Click="SaveButton_OnClick"
                            Content="保存"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="18,16,18,12" LastChildFill="False">
                    <TextBlock VerticalAlignment="Center"
                               DockPanel.Dock="Left"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="受管进程列表" />
                    <TextBlock VerticalAlignment="Center"
                               DockPanel.Dock="Right"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="勾选后可批量执行运行、停止、重启、删除。" />
                </DockPanel>

                <DataGrid x:Name="TargetsGrid"
                          Grid.Row="1"
                          Margin="10,0,10,10"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="90">
                            <DataGridTemplateColumn.Header>
                                <CheckBox x:Name="SelectAllCheckBox"
                                          HorizontalAlignment="Center"
                                          Checked="SelectAllCheckBox_OnChecked"
                                          Content="全选"
                                          IsThreeState="True"
                                          Unchecked="SelectAllCheckBox_OnUnchecked" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Checked="RowCheckBox_OnChanged"
                                              IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource GridCheckBoxStyle}"
                                              Unchecked="RowCheckBox_OnChanged" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Width="72"
                                            Binding="{Binding StartOrder}"
                                            EditingElementStyle="{StaticResource GridEditingTextBoxStyle}"
                                            ElementStyle="{StaticResource GridTextStyle}"
                                            Header="顺序"
                                            IsReadOnly="True" />
                        <DataGridTextColumn Width="150"
                                            Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                            EditingElementStyle="{StaticResource GridEditingTextBoxStyle}"
                                            ElementStyle="{StaticResource GridTextStyle}"
                                            Header="名称" />
                        <DataGridTextColumn Width="3.1*"
                                            Binding="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                                            EditingElementStyle="{StaticResource GridEditingTextBoxStyle}"
                                            ElementStyle="{StaticResource GridTextStyle}"
                                            Header="程序路径" />
                        <DataGridTextColumn Width="1.8*"
                                            Binding="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                            EditingElementStyle="{StaticResource GridEditingTextBoxStyle}"
                                            ElementStyle="{StaticResource GridTextStyle}"
                                            Header="启动参数" />
                        <DataGridTextColumn Width="2*"
                                            Binding="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                            EditingElementStyle="{StaticResource GridEditingTextBoxStyle}"
                                            ElementStyle="{StaticResource GridTextStyle}"
                                            Header="工作目录" />
                        <DataGridCheckBoxColumn Width="88"
                                                Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                EditingElementStyle="{StaticResource GridCheckBoxStyle}"
                                                ElementStyle="{StaticResource GridCheckBoxStyle}"
                                                Header="启用" />
                        <DataGridTemplateColumn Width="190" Header="运行状态" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="12,4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{Binding StatusText, Converter={StaticResource StatusBrushConverter}, ConverterParameter=Fill}"
                                            BorderBrush="{Binding StatusText, Converter={StaticResource StatusBrushConverter}, ConverterParameter=Border}"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding StatusText, Converter={StaticResource StatusBrushConverter}, ConverterParameter=Foreground}"
                                                   Text="{Binding StatusText}"
                                                   TextAlignment="Center" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,18,0,0"
                Padding="16"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Click="MoveUpButton_OnClick" Content="上移" Style="{StaticResource ToolButtonStyle}" />
                <Button Click="MoveDownButton_OnClick" Content="下移" Style="{StaticResource ToolButtonStyle}" />
                <Button Click="AddButton_OnClick" Content="新增" Style="{StaticResource ToolButtonStyle}" />
                <Button Click="DeleteButton_OnClick" Content="删除" Style="{StaticResource DangerButtonStyle}" />
                <Button Click="RunButton_OnClick" Content="运行" Style="{StaticResource ToolButtonStyle}" />
                <Button Click="StopButton_OnClick" Content="停止" Style="{StaticResource DangerButtonStyle}" />
                <Button Margin="0"
                        Click="RestartButton_OnClick"
                        Content="重启"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
